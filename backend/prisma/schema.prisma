// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String?  @unique @db.VarChar(100)
  email     String?  @unique @db.VarChar(255)
  password  String?  @db.VarChar(255)
  fullName  String?  @map("full_name") @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  role      UserRole @default(user)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  oauthProviders UserOAuthProvider[]
  sessions       UserSession[]
  plots          Plot[]
  standardPlans  StandardPlan[]      @relation("CreatedPlans")

  @@index([email])
  @@index([role])
  @@map("users")
}

enum UserRole {
  user
  admin
}

model UserOAuthProvider {
  id             Int       @id @default(autoincrement())
  userId         Int       @map("user_id")
  provider       OAuthProvider
  providerUserId String    @map("provider_user_id") @db.VarChar(255)
  providerData   Json?     @map("provider_data")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId], name: "unique_provider_user")
  @@index([userId])
  @@map("user_oauth_providers")
}

enum OAuthProvider {
  line
  google
  facebook
}

model UserSession {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  refreshToken String   @map("refresh_token") @db.VarChar(500)
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@map("user_sessions")
}

model CropType {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  iconUrl     String?  @map("icon_url") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  varieties CropVariety[]

  @@map("crop_types")
}

model CropVariety {
  id             Int      @id @default(autoincrement())
  cropTypeId     Int      @map("crop_type_id")
  name           String   @db.VarChar(100)
  description    String?  @db.Text
  imageUrl       String?  @map("image_url") @db.VarChar(500)
  additionalInfo Json?    @map("additional_info")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  cropType      CropType         @relation(fields: [cropTypeId], references: [id], onDelete: Cascade)
  standardPlans StandardPlan[]
  cycles        PlantingCycle[]

  @@index([cropTypeId])
  @@map("crop_varieties")
}

model StandardPlan {
  id            Int      @id @default(autoincrement())
  cropVarietyId Int      @map("crop_variety_id")
  planName      String   @map("plan_name") @db.VarChar(255)
  totalDays     Int      @map("total_days")
  planDetails   Json     @map("plan_details")
  costEstimate  Decimal? @map("cost_estimate") @db.Decimal(10, 2)
  createdBy     Int?     @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  cropVariety CropVariety      @relation(fields: [cropVarietyId], references: [id], onDelete: Cascade)
  creator     User?            @relation("CreatedPlans", fields: [createdBy], references: [id], onDelete: SetNull)
  cycles      PlantingCycle[]

  @@index([cropVarietyId])
  @@map("standard_plans")
}

model ActivityType {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  icon      String?  @db.VarChar(50)
  color     String?  @db.VarChar(7)
  createdAt DateTime @default(now()) @map("created_at")

  activities ActivityLog[]

  @@map("activity_types")
}

model Plot {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  plotName  String   @map("plot_name") @db.VarChar(255)
  areaSqm   Decimal  @map("area_sqm") @db.Decimal(10, 2)
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  soilInfo  Json?    @map("soil_info")
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycles PlantingCycle[]

  @@index([userId])
  @@index([latitude, longitude])
  @@map("plots")
}

model PlantingCycle {
  id                  Int           @id @default(autoincrement())
  plotId              Int           @map("plot_id")
  cropVarietyId       Int           @map("crop_variety_id")
  standardPlanId      Int?          @map("standard_plan_id")
  cycleName           String?       @map("cycle_name") @db.VarChar(255)
  startDate           DateTime      @map("start_date") @db.Date
  endDate             DateTime?     @map("end_date") @db.Date
  status              CycleStatus   @default(active)
  expectedHarvestDate DateTime?     @map("expected_harvest_date") @db.Date
  actualCost          Decimal       @default(0) @map("actual_cost") @db.Decimal(10, 2)
  actualRevenue       Decimal       @default(0) @map("actual_revenue") @db.Decimal(10, 2)
  notes               String?       @db.Text
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  plot          Plot          @relation(fields: [plotId], references: [id], onDelete: Cascade)
  cropVariety   CropVariety   @relation(fields: [cropVarietyId], references: [id])
  standardPlan  StandardPlan? @relation(fields: [standardPlanId], references: [id], onDelete: SetNull)
  activityLogs  ActivityLog[]

  @@index([plotId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("planting_cycles")
}

enum CycleStatus {
  active
  completed
  abandoned
}

model ActivityLog {
  id             Int      @id @default(autoincrement())
  cycleId        Int      @map("cycle_id")
  activityTypeId Int      @map("activity_type_id")
  activityDate   DateTime @map("activity_date") @db.Date
  cost           Decimal  @default(0) @db.Decimal(10, 2)
  revenue        Decimal  @default(0) @db.Decimal(10, 2)
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  cycle        PlantingCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  activityType ActivityType   @relation(fields: [activityTypeId], references: [id])
  images       ActivityImage[]

  @@index([cycleId])
  @@index([activityDate])
  @@map("activity_logs")
}

model ActivityImage {
  id            Int      @id @default(autoincrement())
  activityLogId Int      @map("activity_log_id")
  imageUrl      String   @map("image_url") @db.VarChar(500)
  caption       String?  @db.Text
  uploadedAt    DateTime @default(now()) @map("uploaded_at")

  activityLog ActivityLog @relation(fields: [activityLogId], references: [id], onDelete: Cascade)

  @@index([activityLogId])
  @@map("activity_images")
}
